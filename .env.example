# NEXT_PUBLIC_SITE_URL utilisé pour les canonical, OG, sitemap
NEXT_PUBLIC_SITE_URL=https://www.couverturegironde.fr

# Web3Forms — backend du formulaire /demande-devis
# La clé est publique (visible client-side), non-sensible — peut être commitée
# sur Vercel via Settings > Environment Variables.
# Obtenir une clé gratuite : https://web3forms.com (250 envois/mois gratuits)
NEXT_PUBLIC_WEB3FORMS_KEY=

# Google Indexing API + IndexNow (à configurer plus tard)
# GOOGLE_INDEXING_PRIVATE_KEY=
# INDEXNOW_KEY=

# Google Places API pour synchroniser les avis Google
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACES_PLACE_ID=

# Analytics (Plausible privacy-friendly)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=couverturegironde.fr
